{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build yavchn (prod)",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-File", "${workspaceFolder}/build.ps1"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$go",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
