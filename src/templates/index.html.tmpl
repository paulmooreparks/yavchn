<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ if .Selected }}{{ .Selected.Title }} &middot; yavchn{{ else }}yavchn{{ end }}</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="Three-pane Hacker News reader: story list, reader-mode article, threaded discussion side by side.">
<link rel="icon" type="image/x-icon" href="/static/favicon.ico">
<link rel="stylesheet" href="/static/style.css">
<meta property="og:title" content="yavchn">
<meta property="og:description" content="Three-pane Hacker News reader: story list, reader-mode article, threaded discussion side by side.">
<meta property="og:image" content="https://yavchn.parkscomputing.com/static/logo.png">
<meta property="og:url" content="https://yavchn.parkscomputing.com/">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="yavchn">
<meta name="twitter:description" content="Three-pane Hacker News reader: story list, reader-mode article, threaded discussion side by side.">
<meta name="twitter:image" content="https://yavchn.parkscomputing.com/static/logo.png">
<script>
(function () {
  try {
    var pref = localStorage.getItem('yavchn-theme');
    var theme;
    if (pref === 'dark' || pref === 'light') {
      theme = pref;
    } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
      theme = 'dark';
    } else {
      theme = 'light';
    }
    document.documentElement.dataset.theme = theme;
  } catch (e) { /* no storage / matchMedia */ }
})();
(function () {
  // Splitter positions are stored as percentages so the layout adapts to
  // any viewport (different monitor, window resize). Legacy px values from
  // older sessions are migrated to % against the current viewport on first
  // read and re-persisted, so the next reload starts clean.
  try {
    var w = localStorage.getItem('yavchn-list-w');
    var h = localStorage.getItem('yavchn-article-h');
    if (!w && !h) return;
    var headerH = 38;
    function toPercent(raw, totalPx, key) {
      if (!raw) return null;
      raw = raw.trim();
      if (raw.endsWith('%')) {
        var p = parseFloat(raw);
        if (isNaN(p)) return null;
        // Clamp to sane bounds to defang any corrupt value.
        p = Math.max(10, Math.min(90, p));
        return p.toFixed(2) + '%';
      }
      if (raw.endsWith('px') && totalPx > 0) {
        var n = parseFloat(raw);
        if (isNaN(n)) return null;
        var pct = (n / totalPx) * 100;
        pct = Math.max(10, Math.min(90, pct));
        var out = pct.toFixed(2) + '%';
        try { localStorage.setItem(key, out); } catch (e) {}
        return out;
      }
      return null;
    }
    var listW = toPercent(w, window.innerWidth, 'yavchn-list-w');
    var artH  = toPercent(h, window.innerHeight - headerH, 'yavchn-article-h');
    if (!listW && !artH) return;
    var css = '.layout {';
    if (listW) css += ' --list-w: ' + listW + ';';
    if (artH)  css += ' --article-h: ' + artH + ';';
    css += ' }';
    var s = document.createElement('style');
    s.textContent = css;
    document.head.appendChild(s);
  } catch (e) { /* no storage */ }
})();
(function () {
  // Apply persisted focus-mode before first paint so the list pane doesn't
  // flash visible on reload of a focus-mode session.
  try {
    if (localStorage.getItem('yavchn-focus') === '1') {
      document.documentElement.classList.add('focus-mode');
    }
  } catch (e) { /* no storage */ }
})();
</script>
</head>
<body>
<header>
  <h1><a href="/"><img src="/static/logo-24x24.png" alt="" class="logo"> yavchn</a></h1>
  <nav class="source-picker" aria-label="News source">
    {{ range .AllSources }}
    <a href="{{ .URL }}" class="source-pick{{ if .Active }} active{{ end }}" data-source="{{ .Name }}">{{ .Label }}</a>
    {{ end }}
  </nav>
  <button type="button" class="hamburger-btn" aria-label="Header menu" aria-expanded="false" aria-controls="header-actions">
    <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
      <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" fill="none"/>
    </svg>
  </button>
  <div class="header-actions" id="header-actions">
    <a class="source-link hn-link" href="https://news.ycombinator.com/" target="_blank" rel="noopener" title="Hacker News (source)" aria-label="Hacker News (source)">
      <img src="https://news.ycombinator.com/y18.svg" alt="" width="18" height="18">
    </a>
    <a class="source-link lobsters-link" href="https://lobste.rs/" target="_blank" rel="noopener" title="Lobsters (source)" aria-label="Lobsters (source)">
      <img src="/static/lobsters.svg" alt="" width="18" height="18">
    </a>
    <a class="source-link github-link" href="https://github.com/paulmooreparks/yavchn" target="_blank" rel="noopener" title="Source on GitHub" aria-label="Source on GitHub">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
    </a>
    <a class="mail-button" href="mailto:paul@parkscomputing.com" title="Email Paul" aria-label="Email Paul">&#9993;</a>
    <button type="button" class="theme-toggle" title="Toggle light/dark theme" aria-label="Toggle theme">
      <span class="icon-dark" aria-hidden="true">&#9790;</span><span class="icon-light" aria-hidden="true">&#9728;</span>
    </button>
    <button type="button" class="focus-button help-button" title="Focus mode (f)" aria-label="Toggle focus mode" aria-pressed="false">&#9716;</button>
    <button type="button" class="filters-button help-button" title="Domain filters" aria-label="Domain filters" aria-haspopup="dialog">&#9881;</button>
    <button type="button" class="help-trigger help-button" title="Help (?)" aria-label="Help" aria-haspopup="dialog">?</button>
  </div>
</header>

<dialog id="filters-dialog" class="help-dialog" aria-labelledby="filters-dialog-title">
  <div class="help-dialog-frame">
    <header class="help-dialog-header">
      <h2 id="filters-dialog-title">Domain filters</h2>
      <button type="button" class="help-dialog-close" aria-label="Close domain filters">&times;</button>
    </header>
    <div class="help-dialog-body filters-body">
      <p class="filters-intro">Stories from these domains are hidden from the list. Subdomains match too (blocking <code>substack.com</code> also hides <code>danluu.substack.com</code>).</p>
      <ul class="filters-list" aria-label="Blocked domains"></ul>
      <p class="filters-empty" hidden>No domains blocked yet.</p>
      <form class="filters-add">
        <input type="text" name="domain" class="filters-add-input" placeholder="example.com" autocomplete="off" spellcheck="false" aria-label="Add domain to block">
        <button type="submit" class="filters-add-btn">Block</button>
      </form>
    </div>
  </div>
</dialog>

<dialog id="help-dialog" class="help-dialog" aria-labelledby="help-dialog-title">
  <div class="help-dialog-frame">
    <header class="help-dialog-header">
      <h2 id="help-dialog-title">Help</h2>
      <button type="button" class="help-dialog-close" aria-label="Close help">&times;</button>
    </header>
    <div class="help-dialog-body">

      <section>
        <h3>Keyboard</h3>
        <dl>
          <dt><kbd>j</kbd> / <kbd>&darr;</kbd></dt>
          <dd>Move focus down the story list</dd>
          <dt><kbd>k</kbd> / <kbd>&uarr;</kbd></dt>
          <dd>Move focus up the story list</dd>
          <dt><kbd>Enter</kbd></dt>
          <dd>Open the focused story (loads its article and discussion in the right panes)</dd>
          <dt><kbd>n</kbd> / <kbd>N</kbd></dt>
          <dd>Jump to the next / previous top-level comment in the discussion (the focused comment is highlighted)</dd>
          <dt><kbd>c</kbd></dt>
          <dd>Collapse / expand the focused top-level comment</dd>
          <dt><kbd>f</kbd></dt>
          <dd>Toggle focus mode (hide the story list to give the article + discussion the full width)</dd>
          <dt><kbd>p</kbd></dt>
          <dd>Pin / unpin the focused story (saves it to the Pinned tab)</dd>
          <dt><kbd>s</kbd></dt>
          <dd>Cycle focus through the splitter bars (then use arrow keys to resize; <kbd>Esc</kbd> exits)</dd>
          <dt><kbd>?</kbd></dt>
          <dd>Toggle this help</dd>
          <dt><kbd>Esc</kbd></dt>
          <dd>Close this help</dd>
        </dl>
      </section>

      <section>
        <h3>Mouse and touch</h3>
        <ul>
          <li>Click a story title to load its article and discussion in the right panes; the list stays where you left it (your scroll position and any infinite-scrolled extra rows are preserved).</li>
          <li>Scroll the story list down past the visible rows to load more stories.</li>
          <li>Drag the splitter bars between panes to resize them; the layout you chose persists across reloads.</li>
          <li>Click <strong>Open original &uarr;</strong> in the article pane to read the full source page in a new tab.</li>
          <li>Click <strong>Open on HN &uarr;</strong> in the discussion pane (or the small &uarr; next to any comment) to vote, reply, save, or hide on news.ycombinator.com.</li>
        </ul>
      </section>

      <section>
        <h3>Source tabs</h3>
        <p>The tabs above the story list switch the feed: <strong>Pinned</strong>, <strong>Top</strong>, <strong>Show HN</strong>, <strong>Ask HN</strong>, <strong>New</strong>, <strong>Best</strong>, <strong>Jobs</strong>.</p>
      </section>

      <section>
        <h3>Pinned</h3>
        <p>Each story row carries a small outline pin at the far left. Click it to save that story for later; the glyph fills in to show it's pinned. The <strong>Pinned</strong> tab at the start of the source-tabs row collects everything you've saved, even after it falls off the HN front page. Pinned state is stored in your browser only &mdash; nothing is sent to the server.</p>
      </section>

      <section>
        <h3>Theme</h3>
        <p>The sun/moon button in the header toggles between light and dark themes. The first visit follows your operating system's preference.</p>
      </section>

      <section>
        <h3>About</h3>
        <p>yavchn never sees your HN credentials. The discussion is fetched server-side and rendered into the pane; logged-in actions hand off to news.ycombinator.com in a new tab where your existing session does the work.</p>
        <p>Open source: <a href="https://github.com/paulmooreparks/yavchn" target="_blank" rel="noopener">github.com/paulmooreparks/yavchn</a>.</p>
      </section>

    </div>
  </div>
</dialog>
<div class="layout">

  <aside class="pane pane-list" data-source="{{ .Source }}">
    {{ if .ShowSearch }}
    <form class="search-bar" action="/hn/search" method="get" role="search">
      <div class="search-bar-frame">
        <input type="search" name="q" placeholder="Search HN&hellip;" value="{{ .Query }}" aria-label="Search Hacker News" autocomplete="off">
        <button type="submit" class="search-submit" aria-label="Search">
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
            <circle cx="7" cy="7" r="4" fill="none" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10" y1="10" x2="14" y2="14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </form>
    {{ end }}
    <nav class="source-tabs">
    {{ range .Tabs }}
      <a href="{{ .URL }}"{{ if .Active }} class="active"{{ end }}>{{ .Label }}</a>
    {{ end }}
    </nav>
    {{ if .ListError }}
    <div class="list-error">
      <h2>Front page unavailable</h2>
      <p>{{ .ListError }}</p>
      <p><a class="cta" href="{{ .RetryURL }}">Retry</a></p>
    </div>
    {{ else }}
    <ul class="stories" data-has-next="{{ if .HasNext }}true{{ else }}false{{ end }}">
    {{ range .Stories }}
    <li class="story{{ if .Selected }} selected{{ end }}" data-id="{{ .ID }}" data-source="{{ .Source }}" data-url="{{ .URL }}" data-host="{{ .Host }}" data-by="{{ .By }}" data-score="{{ .Score }}" data-comments="{{ .Comments }}">
      <button type="button" class="pin-btn" title="Pin this story" aria-label="Pin this story" aria-pressed="false">
        <svg class="pin-icon" viewBox="0 0 16 16" width="12" height="12" aria-hidden="true">
          <path d="M5 2h6v3l2 3H9v6l-1 1-1-1V8H3l2-3V2z"/>
        </svg>
      </button>
      <span class="rank">{{ .Rank }}.</span>
      <div class="body">
        <div class="title"><a href="{{ .SelectURL }}">{{ .Title }}</a></div>
        <div class="meta">
          <a class="host" href="{{ .URL }}" target="_blank" rel="noopener">{{ .Host }} &uarr;</a>
          &middot; {{ .Score }} pts
          &middot; {{ .By }}
          &middot; {{ .Age }}
          &middot; {{ .Comments }} comments
        </div>
      </div>
      <button type="button" class="dismiss-btn" title="Hide this story" aria-label="Hide this story">&times;</button>
    </li>
    {{ end }}
    </ul>
    <div class="hidden-banner" hidden><button type="button" class="hidden-banner-show">&nbsp;</button></div>
    <nav class="pager">
      {{ if .HasPrev }}<a href="{{ .PrevURL }}">&larr; prev</a>{{ else }}<span class="disabled">&larr; prev</span>{{ end }}
      <span class="page-num">page {{ .Page }}</span>
      {{ if .HasNext }}<a href="{{ .NextURL }}">next &rarr;</a>{{ else }}<span class="disabled">next &rarr;</span>{{ end }}
    </nav>
    {{ end }}
  </aside>

  <div class="splitter splitter-v" role="separator" aria-orientation="vertical"></div>

  <section class="pane pane-article"{{ if and .Selected .Selected.HasArticle }} data-reader-url="{{ .Selected.URL }}"{{ end }}>
    {{ if .SelectError }}
      <div class="pane-header"><span class="pane-label">article</span></div>
      <div class="pane-body">
        <div class="article-stub">
          <h2>Story unavailable</h2>
          <p class="note">{{ .SelectError }}</p>
        </div>
      </div>
    {{ else if .Selected }}
      <div class="pane-header">
        <span class="pane-label">article</span>
        {{ if .Selected.HasArticle }}<a href="{{ .Selected.URL }}" target="_blank" rel="noopener">Open original &uarr;</a>{{ end }}
      </div>
      <div class="pane-body">
        {{ if .Selected.HasArticle }}
          <div class="article-stub">
            <h2>{{ .Selected.Title }}</h2>
            <p class="article-host">{{ .Selected.Host }}</p>
            <a class="cta" href="{{ .Selected.URL }}" target="_blank" rel="noopener">Open article &uarr;</a>
            <p class="note js-reader-status">Loading reader-mode&hellip;</p>
            <noscript><p class="note">Reader-mode requires JavaScript. The "Open article" link above works without it.</p></noscript>
          </div>
        {{ else }}
          <div class="article-stub">
            <h2>{{ .Selected.Title }}</h2>
            <p class="note">This is a self-post &mdash; see the discussion below.</p>
          </div>
        {{ end }}
      </div>
    {{ else }}
      <div class="article-stub empty"><p>Click a story to view its article.</p></div>
    {{ end }}
  </section>

  <div class="splitter splitter-h" role="separator" aria-orientation="horizontal"></div>

  <section class="pane pane-discussion"{{ if .Selected }} data-discussion-id="{{ .Selected.ID }}" data-discussion-source="{{ .Selected.Source }}"{{ end }}>
    {{ if .SelectError }}
      <div class="pane-header"><span class="pane-label">discussion</span></div>
      <div class="pane-body">
        <p class="empty-note">{{ .SelectError }}</p>
      </div>
    {{ else if .Selected }}
      <div class="pane-header">
        <span class="pane-label">discussion</span>
        <label class="comment-sort-wrap"><span class="visually-hidden">Sort comments</span>
          <select class="comment-sort" aria-label="Sort comments">
            <option value="best">Best</option>
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
          </select>
        </label>
        <a href="{{ .Selected.HNURL }}" target="_blank" rel="noopener">{{ .Selected.ExternalLabel }} &uarr;</a>
      </div>
      <div class="pane-body">
        <p class="empty-note js-discussion-status">Loading discussion&hellip;</p>
        <noscript><p class="empty-note">Discussion requires JavaScript. Use "Open on HN" above.</p></noscript>
      </div>
    {{ else }}
      <div class="article-stub empty"><p>Click a story to view the discussion.</p></div>
    {{ end }}
  </section>

</div>
<script src="/static/reader.js" defer></script>
<script src="/static/splitters.js" defer></script>
<script src="/static/theme.js" defer></script>
<script src="/static/keys.js" defer></script>
<script src="/static/infinite.js" defer></script>
<script src="/static/swap.js" defer></script>
<script src="/static/help.js" defer></script>
<script src="/static/discussion.js" defer></script>
<script src="/static/search.js" defer></script>
<script src="/static/visited.js" defer></script>
<script src="/static/prefetch.js" defer></script>
<script src="/static/dismissed.js" defer></script>
<script src="/static/sort.js" defer></script>
<script src="/static/focus.js" defer></script>
<script src="/static/filters.js" defer></script>
<script src="/static/pinned.js" defer></script>
<script src="/static/menu.js" defer></script>
</body>
</html>
