<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ if .Selected }}{{ .Selected.Title }} &middot; yavchn{{ else }}yavchn{{ end }}</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="Three-pane Hacker News reader: story list, reader-mode article, threaded discussion side by side.">
<link rel="icon" type="image/x-icon" href="/static/favicon.ico">
<link rel="stylesheet" href="/static/style.css">
<meta property="og:title" content="yavchn">
<meta property="og:description" content="Three-pane Hacker News reader: story list, reader-mode article, threaded discussion side by side.">
<meta property="og:image" content="https://yavchn.parkscomputing.com/static/logo.png">
<meta property="og:url" content="https://yavchn.parkscomputing.com/">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="yavchn">
<meta name="twitter:description" content="Three-pane Hacker News reader: story list, reader-mode article, threaded discussion side by side.">
<meta name="twitter:image" content="https://yavchn.parkscomputing.com/static/logo.png">
<script>
(function () {
  try {
    var pref = localStorage.getItem('yavchn-theme');
    var theme;
    if (pref === 'dark' || pref === 'light') {
      theme = pref;
    } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
      theme = 'dark';
    } else {
      theme = 'light';
    }
    document.documentElement.dataset.theme = theme;
  } catch (e) { /* no storage / matchMedia */ }
})();
(function () {
  try {
    var w = localStorage.getItem('yavchn-list-w');
    var h = localStorage.getItem('yavchn-article-h');
    if (!w && !h) return;
    var css = '.layout {';
    if (w) css += ' --list-w: ' + w + ';';
    if (h) css += ' --article-h: ' + h + ';';
    css += ' }';
    var s = document.createElement('style');
    s.textContent = css;
    document.head.appendChild(s);
  } catch (e) { /* no storage */ }
})();
</script>
</head>
<body>
<header>
  <h1><a href="/"><img src="/static/logo-24x24.png" alt="" class="logo"> yavchn</a></h1>
  <div class="header-actions">
    <a class="source-link" href="https://github.com/paulmooreparks/yavchn" target="_blank" rel="noopener" title="Source on GitHub" aria-label="Source on GitHub">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.4 3-.405 1.02.005 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
    </a>
    <button type="button" class="theme-toggle" title="Toggle light/dark theme" aria-label="Toggle theme">
      <span class="icon-dark" aria-hidden="true">&#9790;</span><span class="icon-light" aria-hidden="true">&#9728;</span>
    </button>
  </div>
</header>
<div class="layout">

  <aside class="pane pane-list">
    <nav class="source-tabs">
    {{ range .Tabs }}
      <a href="{{ .URL }}"{{ if .Active }} class="active"{{ end }}>{{ .Label }}</a>
    {{ end }}
    </nav>
    {{ if .ListError }}
    <div class="list-error">
      <h2>Front page unavailable</h2>
      <p>{{ .ListError }}</p>
      <p><a class="cta" href="{{ .RetryURL }}">Retry</a></p>
    </div>
    {{ else }}
    <ul class="stories" data-has-next="{{ if .HasNext }}true{{ else }}false{{ end }}">
    {{ range .Stories }}
    <li class="story{{ if .Selected }} selected{{ end }}">
      <span class="rank">{{ .Rank }}.</span>
      <div class="body">
        <div class="title"><a href="{{ .SelectURL }}">{{ .Title }}</a></div>
        <div class="meta">
          <a class="host" href="{{ .URL }}" target="_blank" rel="noopener">{{ .Host }} &uarr;</a>
          &middot; {{ .Score }} pts
          &middot; {{ .By }}
          &middot; {{ .Age }}
          &middot; {{ .Comments }} comments
        </div>
      </div>
    </li>
    {{ end }}
    </ul>
    <nav class="pager">
      {{ if .HasPrev }}<a href="{{ .PrevURL }}">&larr; prev</a>{{ else }}<span class="disabled">&larr; prev</span>{{ end }}
      <span class="page-num">page {{ .Page }}</span>
      {{ if .HasNext }}<a href="{{ .NextURL }}">next &rarr;</a>{{ else }}<span class="disabled">next &rarr;</span>{{ end }}
    </nav>
    {{ end }}
  </aside>

  <div class="splitter splitter-v" role="separator" aria-orientation="vertical"></div>

  <section class="pane pane-article"{{ if and .Selected .Selected.HasArticle }} data-reader-url="{{ .Selected.URL }}"{{ end }}>
    {{ if .SelectError }}
      <div class="pane-header"><span class="pane-label">article</span></div>
      <div class="pane-body">
        <div class="article-stub">
          <h2>Story unavailable</h2>
          <p class="note">{{ .SelectError }}</p>
        </div>
      </div>
    {{ else if .Selected }}
      <div class="pane-header">
        <span class="pane-label">article</span>
        {{ if .Selected.HasArticle }}<a href="{{ .Selected.URL }}" target="_blank" rel="noopener">Open original &uarr;</a>{{ end }}
      </div>
      <div class="pane-body">
        {{ if .Selected.HasArticle }}
          <div class="article-stub">
            <h2>{{ .Selected.Title }}</h2>
            <p class="article-host">{{ .Selected.Host }}</p>
            <a class="cta" href="{{ .Selected.URL }}" target="_blank" rel="noopener">Open article &uarr;</a>
            <p class="note js-reader-status">Loading reader-mode&hellip;</p>
            <noscript><p class="note">Reader-mode requires JavaScript. The "Open article" link above works without it.</p></noscript>
          </div>
        {{ else }}
          <div class="article-stub">
            <h2>{{ .Selected.Title }}</h2>
            <p class="note">This is a self-post &mdash; see the discussion below.</p>
          </div>
        {{ end }}
      </div>
    {{ else }}
      <div class="article-stub empty"><p>Click a story to view its article.</p></div>
    {{ end }}
  </section>

  <div class="splitter splitter-h" role="separator" aria-orientation="horizontal"></div>

  <section class="pane pane-discussion"{{ if .Selected }} data-discussion-id="{{ .Selected.ID }}"{{ end }}>
    {{ if .SelectError }}
      <div class="pane-header"><span class="pane-label">discussion</span></div>
      <div class="pane-body">
        <p class="empty-note">{{ .SelectError }}</p>
      </div>
    {{ else if .Selected }}
      <div class="pane-header">
        <span class="pane-label">discussion</span>
        <a href="{{ .Selected.HNURL }}" target="_blank" rel="noopener">Open on HN &uarr;</a>
      </div>
      <div class="pane-body">
        <p class="empty-note js-discussion-status">Loading discussion&hellip;</p>
        <noscript><p class="empty-note">Discussion requires JavaScript. Use "Open on HN" above.</p></noscript>
      </div>
    {{ else }}
      <div class="article-stub empty"><p>Click a story to view the discussion.</p></div>
    {{ end }}
  </section>

</div>
<script src="/static/reader.js" defer></script>
<script src="/static/splitters.js" defer></script>
<script src="/static/theme.js" defer></script>
<script src="/static/keys.js" defer></script>
<script src="/static/infinite.js" defer></script>
<script src="/static/swap.js" defer></script>
</body>
</html>
